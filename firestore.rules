rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /employees/{employeeId} {
      allow read;
      allow write: if isSignedIn();
    }

    match /attendance/{attendanceRecordId} {
      allow read;
      allow write: if isSignedIn();
    }

    match /absences/{absenceId} {
      allow read;
      allow write: if isSignedIn();
    }

    match /sanctions/{sanctionId} {
      allow read;
      allow write: if isSignedIn();
    }

    match /bonuses/{bonusId} {
      allow read, write: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    match /holidays/{holidayId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /savings/{employeeId} {
      allow read, write: if isSignedIn();
    }

    match /savings-transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    match /payrolls/{payrollId} {
      // Allow payroll document to be public for payslip access
      allow read;
      allow write: if isSignedIn();

      match /payslips/{payslipId} {
        // Allow anyone with the link to read.
        allow read;
        // Only signed-in users can manage payslips.
        allow write, delete: if isSignedIn();
      }
    }
  }
}
