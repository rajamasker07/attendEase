
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      // Periksa apakah pengguna sudah diautentikasi.
      return request.auth != null;
    }

    // Aturan default: Semua akses (baca & tulis) ke semua dokumen
    // memerlukan pengguna untuk masuk.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Pengecualian: Izinkan baca publik untuk slip gaji tunggal.
    // Ini menimpa aturan di atas HANYA untuk metode 'get' pada path spesifik ini.
    // Metode 'list', 'write', dan 'delete' tetap dilindungi oleh aturan default.
    match /payrolls/{payrollId}/payslips/{payslipId} {
      allow get;
    }
  }
}
