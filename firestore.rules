
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Secure by default: All reads and writes for all documents require an authenticated user.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // EXCEPTION: Allow public access for viewing a single payslip via a direct link.
    // The 'get' rule allows reading a single document, but 'list' (querying the collection)
    // is still protected by the isSignedIn() check from the wildcard rule. This is secure.
    match /payrolls/{payrollId}/payslips/{payslipId} {
      allow get;
    }
  }
}
