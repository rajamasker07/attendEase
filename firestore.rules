
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /employees/{employeeId} {
      allow read, write: if isSignedIn();
    }

    match /attendance/{attendanceRecordId} {
      allow read, write: if isSignedIn();
    }
  }
}
