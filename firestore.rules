
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Publicly readable data
    match /employees/{employeeId} {
      allow read;
      allow write: if isSignedIn();
    }

    match /attendance/{attendanceRecordId} {
      allow read;
      allow write: if isSignedIn();
    }

    match /absences/{absenceId} {
      allow read;
      allow write: if isSignedIn();
    }

    match /sanctions/{sanctionId} {
      allow read;
      allow write: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read;
      allow write: if isSignedIn();
    }

    // Payroll data is more sensitive and requires sign-in for viewing lists
    match /payrolls/{payrollId} {
      allow read, write: if isSignedIn();

      match /payslips/{payslipId} {
        // Exception: Allow anyone with the direct link to read a single payslip.
        allow read;
        allow write, delete: if isSignedIn();
      }
    }
  }
}
